{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lichtkunst-cc",
  "compatibility_date": "2026-01-01",
  "main": "./worker/index.js",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lichtkunst-comments",
      "database_id": "7d0b6adb-c26a-4384-bdc2-b7d4b1838db1"
    }
  ],
  "send_email": [
    { "name": "SEB" }
  ]
}
