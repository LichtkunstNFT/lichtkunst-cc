---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<section
  id="kommentare"
  data-slug={slug}
  class="mt-16 pt-10 border-t border-[var(--color-border)]/40"
>
  <div class="text-[0.65rem] tracking-[0.4em] uppercase text-[var(--color-accent)] mb-3">
    Deine Stimme
  </div>
  <h2 class="heading-serif text-2xl md:text-3xl text-[var(--color-foreground)] mb-3">
    Kommentare
  </h2>
  <p class="text-lg text-white mb-8">
    Was löst das Werk bei dir aus? Schreib es hier — oder antworte direkt auf
    einen Kommentar. Jeder Kommentar hat einen eigenen Link zum Teilen.
  </p>

  <ul id="kommentar-liste" class="space-y-6 mb-12">
    <li class="text-lg text-[var(--color-muted-foreground)]/60 italic">
      Kommentare werden geladen …
    </li>
  </ul>

  <form id="kommentar-form" class="space-y-4 max-w-xl scroll-mt-24">
    <h3 id="kommentar-form-titel" class="heading-serif text-xl text-[var(--color-foreground)]">
      Antwort auf den Artikel
    </h3>

    <div
      id="antwort-hinweis"
      hidden
      class="flex items-center justify-between gap-3 flex-wrap border border-[var(--color-accent)]/50 rounded-sm bg-[var(--color-card)]/60 px-4 py-3 text-base text-white"
    >
      <span>↩ Du antwortest auf <a id="antwort-ziel" href="#kommentare" class="text-[var(--color-accent)] underline underline-offset-4"></a></span>
      <button
        type="button"
        id="antwort-abbrechen"
        class="text-sm text-[var(--color-muted-foreground)] hover:text-[var(--color-accent)] underline underline-offset-2"
      >
        ✕ stattdessen auf den Artikel antworten
      </button>
    </div>

    <div class="flex flex-col sm:flex-row gap-4">
      <input
        type="text"
        name="name"
        required
        maxlength="80"
        placeholder="Name"
        class="flex-1 bg-[var(--color-card)]/60 border border-[var(--color-border)]/60 rounded-sm px-4 py-3 text-lg text-white placeholder:text-[var(--color-muted-foreground)]/50 focus:outline-none focus:border-[var(--color-accent)]/60"
      />
      <input
        type="email"
        name="email"
        required
        maxlength="120"
        placeholder="E-Mail (wird nicht angezeigt)"
        class="flex-1 bg-[var(--color-card)]/60 border border-[var(--color-border)]/60 rounded-sm px-4 py-3 text-lg text-white placeholder:text-[var(--color-muted-foreground)]/50 focus:outline-none focus:border-[var(--color-accent)]/60"
      />
    </div>

    <textarea
      name="body"
      required
      rows="4"
      maxlength="5000"
      placeholder="Dein Gedanke zum Werk …"
      class="w-full bg-[var(--color-card)]/60 border border-[var(--color-border)]/60 rounded-sm px-4 py-3 text-lg text-white placeholder:text-[var(--color-muted-foreground)]/50 focus:outline-none focus:border-[var(--color-accent)]/60 resize-y"
    ></textarea>

    {/* Honeypot — von Menschen unsichtbar, muss leer bleiben */}
    <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;height:0;overflow:hidden">
      <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
    </div>

    <label class="flex items-start gap-3 text-base text-white leading-relaxed cursor-pointer select-none">
      <input type="checkbox" name="newsletter" class="mt-1 h-5 w-5 shrink-0 accent-[var(--color-accent)] cursor-pointer" />
      <span>
        Ja, ich möchte zusätzlich den <span class="text-[var(--color-accent)]">Newsletter</span>
        erhalten — neue Werke, Ausstellungen, Texte, gelegentlich per Mail.
        Anmeldung erst nach Bestätigung per E-Mail (Double Opt-In), Abmeldung jederzeit.
      </span>
    </label>

    <div class="flex items-center justify-between gap-4">
      <p id="kommentar-status" class="text-xs text-[var(--color-muted-foreground)]/70" role="status" aria-live="polite"></p>
      <button
        type="submit"
        class="inline-flex items-center px-6 py-2.5 rounded-sm bg-[var(--color-accent)] text-[var(--color-accent-foreground)] text-sm tracking-[0.12em] uppercase font-medium glow-amber-sm hover:glow-amber transition-shadow disabled:opacity-50"
      >
        Absenden
      </button>
    </div>
    <p class="text-[0.7rem] text-[var(--color-muted-foreground)]/50 leading-relaxed">
      Name und Kommentar erscheinen öffentlich. Die E-Mail-Adresse ist
      erforderlich, bleibt aber privat und dient nur für eine eventuelle
      Rückmeldung. Gespeichert wird ausschließlich in der EU (Cloudflare),
      kein Tracking. Mehr in der
      <a href="/datenschutz" class="underline underline-offset-2 hover:text-[var(--color-accent)]">Datenschutzerklärung</a>.
    </p>
  </form>
</section>

<style is:global>
  /* Angesprungener Kommentar (#kommentar-…) leuchtet auf */
  #kommentare li:target > article {
    border-color: var(--color-accent);
    box-shadow:
      0 0 0 1px oklch(0.72 0.14 68 / 0.3),
      0 0 20px oklch(0.72 0.14 68 / 0.15);
  }
</style>

<script>
  const root = document.getElementById("kommentare");
  if (root) {
    const slug = root.dataset.slug;
    const liste = document.getElementById("kommentar-liste");
    const form = document.getElementById("kommentar-form");
    const formTitel = document.getElementById("kommentar-form-titel");
    const statusEl = document.getElementById("kommentar-status");
    const hinweis = document.getElementById("antwort-hinweis");
    const hinweisZiel = document.getElementById("antwort-ziel");
    const hinweisAbbrechen = document.getElementById("antwort-abbrechen");
    const loadedAt = Date.now();
    let comments = [];
    let antwortAuf = null; // Kommentar-Objekt oder null = Artikel

    const fmt = (ms) =>
      new Date(ms).toLocaleDateString("de-DE", {
        year: "numeric",
        month: "long",
        day: "numeric",
      });

    function setAntwortAuf(c) {
      antwortAuf = c;
      if (c) {
        hinweisZiel.textContent = "Kommentar #" + c.id + " von " + c.name;
        hinweisZiel.href = "#kommentar-" + c.id;
        hinweis.hidden = false;
        formTitel.textContent = "Antwort auf Kommentar #" + c.id;
      } else {
        hinweis.hidden = true;
        formTitel.textContent = "Antwort auf den Artikel";
      }
    }

    function baueKommentar(c) {
      const li = document.createElement("li");
      li.id = "kommentar-" + c.id;
      li.className = "scroll-mt-24";

      const art = document.createElement("article");
      art.className =
        "border border-[var(--color-border)]/60 rounded-sm bg-[var(--color-card)]/40 p-4 sm:p-5 transition-shadow";

      // Eigene Überschrift pro Kommentar
      const eyebrow = document.createElement("a");
      eyebrow.href = "#kommentar-" + c.id;
      eyebrow.className =
        "block text-[0.65rem] tracking-[0.3em] uppercase text-[var(--color-accent)] mb-1 no-underline hover:underline underline-offset-4";
      eyebrow.textContent = "Kommentar #" + c.id;

      const head = document.createElement("div");
      head.className = "flex items-baseline gap-3 flex-wrap mb-2";
      const name = document.createElement("h3");
      name.className = "heading-serif text-xl text-white m-0";
      name.textContent = c.name;
      const datum = document.createElement("span");
      datum.className = "text-sm text-[var(--color-muted-foreground)]";
      datum.textContent = fmt(c.created_at);
      head.appendChild(name);
      head.appendChild(datum);

      const p = document.createElement("p");
      p.className = "text-lg text-white leading-relaxed whitespace-pre-wrap m-0";
      p.textContent = c.body;

      const actions = document.createElement("div");
      actions.className = "flex gap-5 mt-3";

      const antworten = document.createElement("button");
      antworten.type = "button";
      antworten.className =
        "text-sm tracking-[0.08em] uppercase text-[var(--color-accent)] hover:underline underline-offset-4";
      antworten.textContent = "↩ Antworten";
      antworten.addEventListener("click", () => {
        setAntwortAuf(c);
        form.scrollIntoView({ behavior: "smooth", block: "start" });
        form.querySelector("textarea").focus({ preventScroll: true });
      });

      const link = document.createElement("button");
      link.type = "button";
      link.className =
        "text-sm tracking-[0.08em] uppercase text-[var(--color-muted-foreground)] hover:text-[var(--color-accent)] hover:underline underline-offset-4";
      link.textContent = "Link kopieren";
      link.addEventListener("click", async () => {
        const url =
          location.origin + location.pathname + "#kommentar-" + c.id;
        try {
          await navigator.clipboard.writeText(url);
          link.textContent = "Kopiert ✓";
        } catch {
          location.hash = "kommentar-" + c.id;
          link.textContent = "Link in der Adresszeile";
        }
        setTimeout(() => (link.textContent = "Link kopieren"), 2500);
      });

      actions.appendChild(antworten);
      actions.appendChild(link);

      art.appendChild(eyebrow);
      art.appendChild(head);
      art.appendChild(p);
      art.appendChild(actions);
      li.appendChild(art);
      return li;
    }

    function render() {
      liste.innerHTML = "";
      if (!comments.length) {
        const li = document.createElement("li");
        li.className = "text-lg text-[var(--color-muted-foreground)]/60 italic";
        li.textContent = "Noch keine Kommentare — schreib den ersten.";
        liste.appendChild(li);
        return;
      }

      // Baum aufbauen: Antworten hängen unter ihrem Eltern-Kommentar
      const kinder = new Map();
      const wurzeln = [];
      for (const c of comments) {
        const p = c.parent_id;
        if (p && comments.some((x) => x.id === p)) {
          if (!kinder.has(p)) kinder.set(p, []);
          kinder.get(p).push(c);
        } else {
          wurzeln.push(c);
        }
      }

      function haenge(an, liste_, tiefe) {
        for (const c of liste_) {
          const li = baueKommentar(c);
          an.appendChild(li);
          const antworten = kinder.get(c.id);
          if (antworten && antworten.length) {
            const ul = document.createElement("ul");
            ul.className =
              "mt-4 space-y-4 border-l-2 border-[var(--color-accent)]/30 " +
              (tiefe < 3 ? "pl-4 sm:pl-6" : "pl-2");
            li.appendChild(ul);
            haenge(ul, antworten, tiefe + 1);
          }
        }
      }
      haenge(liste, wurzeln, 0);
    }

    function springeZuHash() {
      if (/^#kommentar-\d+$/.test(location.hash)) {
        const ziel = document.getElementById(location.hash.slice(1));
        if (ziel) ziel.scrollIntoView({ block: "start" });
      }
    }

    fetch("/api/comments?slug=" + encodeURIComponent(slug))
      .then((r) => r.json())
      .then((d) => {
        comments = d.comments || [];
        render();
        springeZuHash();
      })
      .catch(() => {
        liste.innerHTML =
          '<li class="text-lg text-[var(--color-muted-foreground)]/60 italic">Kommentare konnten nicht geladen werden.</li>';
      });

    hinweisAbbrechen.addEventListener("click", () => setAntwortAuf(null));

    // Gleiche EmailOctopus-Liste wie das Newsletter-Formular (Double Opt-In).
    const NEWSLETTER_ENDPOINT =
      "https://eocampaign1.com/form/37a6e4fc-6001-11f1-b0c3-9b90a18e68d4";

    async function newsletterAnmelden(email) {
      try {
        const res = await fetch(NEWSLETTER_ENDPOINT, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new URLSearchParams({ field_0: email }),
        });
        const d = await res.json().catch(() => ({}));
        return res.ok && d?.success !== false;
      } catch {
        return false;
      }
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = form.querySelector("button[type=submit]");
      const fd = new FormData(form);
      const email = fd.get("email");
      const newsletter = fd.get("newsletter");
      const payload = {
        slug,
        name: fd.get("name"),
        email,
        body: fd.get("body"),
        website: fd.get("website"),
        parent_id: antwortAuf ? antwortAuf.id : null,
        t: loadedAt,
      };
      btn.disabled = true;
      statusEl.textContent = "Wird gesendet …";
      try {
        const res = await fetch("/api/comments", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        const d = await res.json();
        if (d.ok && d.comment) {
          comments.push(d.comment);
          render();
          form.reset();
          setAntwortAuf(null);
          statusEl.textContent =
            "Danke — dein Kommentar #" + d.comment.id + " ist online.";
          if (newsletter) {
            statusEl.textContent = (await newsletterAnmelden(email))
              ? "Danke — dein Kommentar ist online. Newsletter: bitte bestätige den Link in der E-Mail, die wir dir gerade geschickt haben."
              : "Dein Kommentar ist online. Die Newsletter-Anmeldung hat leider nicht geklappt — bitte nutze das Newsletter-Formular auf der Startseite.";
          }
        } else if (d.ok) {
          form.reset();
          setAntwortAuf(null);
          statusEl.textContent = "Danke.";
        } else {
          statusEl.textContent = d.error || "Konnte nicht gesendet werden.";
        }
      } catch {
        statusEl.textContent = "Netzwerkfehler — bitte später erneut versuchen.";
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
