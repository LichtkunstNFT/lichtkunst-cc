---
import Layout from "../../layouts/Layout.astro";
import Comments from "../../components/Comments.astro";
import PinterestFlow from "../../components/PinterestFlow.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const eintraege = await getCollection("blog", ({ data }) => !data.ausblenden);
  return eintraege.map((eintrag) => ({
    params: { slug: eintrag.id },
    props: { eintrag },
  }));
}

const { eintrag } = Astro.props;
const { Content } = await render(eintrag);

const datum = eintrag.data.datum.toLocaleDateString("de-DE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const weiterlesen = (await getCollection("blog", ({ data }) => !data.ausblenden))
  .filter((e) => e.id !== eintrag.id)
  .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf())
  .slice(0, 3);
---

<Layout
  title={`${eintrag.data.titel} – Journal`}
  description={eintrag.data.untertitel ?? eintrag.data.vorschau}
  image={eintrag.data.titelbild}
  type="article"
>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <header class="mb-10 pb-8 border-b border-[var(--color-border)]/40">
      <div class="text-xs tracking-widest uppercase text-[var(--color-muted-foreground)]/70 mb-3">{datum}</div>
      <h1 class="heading-serif text-3xl md:text-4xl text-[var(--color-foreground)] leading-tight">
        {eintrag.data.titel}
      </h1>
      {eintrag.data.tags && (
        <div class="flex flex-wrap gap-2 mt-5">
          {eintrag.data.tags.map((tag) => (
            <span class="text-[0.6rem] tracking-widest uppercase text-[var(--color-muted-foreground)]/60 border border-[var(--color-border)]/40 rounded-sm px-2 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="font-body text-[var(--color-muted-foreground)] leading-relaxed [&_h2]:heading-serif [&_h2]:text-xl [&_h2]:text-[var(--color-foreground)] [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:font-medium [&_h3]:text-[var(--color-foreground)] [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:mb-4 [&_ul]:list-disc [&_ul]:ml-6 [&_ul]:mb-4 [&_ol]:list-decimal [&_ol]:ml-6 [&_ol]:mb-4 [&_li]:mb-1 [&_em]:text-[var(--color-foreground)] [&_strong]:text-[var(--color-foreground)] [&_a]:text-[var(--color-accent)] [&_a]:underline [&_a]:underline-offset-4 [&_hr]:my-8 [&_hr]:border-[var(--color-border)]/40 [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--color-accent)]/50 [&_blockquote]:pl-5 [&_blockquote]:py-1 [&_blockquote]:my-6 [&_blockquote]:text-[var(--color-foreground)]/80 [&_blockquote]:italic [&_blockquote_strong]:not-italic [&_table]:w-full [&_table]:my-6 [&_table]:text-sm [&_th]:text-left [&_th]:font-medium [&_th]:text-[var(--color-foreground)] [&_th]:border-b [&_th]:border-[var(--color-border)]/40 [&_th]:py-2 [&_th]:pr-4 [&_td]:py-2 [&_td]:pr-4 [&_td]:align-top [&_td]:border-b [&_td]:border-[var(--color-border)]/20 [&_figure]:my-10 [&_figure]:text-center [&_figure_img]:inline-block [&_figure_img]:max-w-full [&_figure_img]:h-auto [&_figcaption]:text-sm [&_figcaption]:text-[var(--color-muted-foreground)]/75 [&_figcaption]:italic [&_figcaption]:mt-4 [&_figcaption]:max-w-md [&_figcaption]:mx-auto [&_figcaption]:leading-relaxed">
      <Content />
    </div>

    <PinterestFlow
      galerie={eintrag.data.galerie}
      pinterestUrl={eintrag.data.pinterest_url}
      pageUrl={`https://lichtkunst.cc/blog/${eintrag.id}`}
      titel={eintrag.data.titel}
      pinZiel={eintrag.data.pin_ziel}
    />

    <Comments slug={eintrag.id} />

    {weiterlesen.length > 0 && (
      <section class="mt-16 pt-10 border-t border-[var(--color-border)]/40">
        <div class="text-[0.65rem] tracking-[0.4em] uppercase text-[var(--color-accent)] mb-6">
          Weiterlesen
        </div>
        <ul class="space-y-6">
          {weiterlesen.map((e) => (
            <li>
              <a href={`/blog/${e.id}`} class="group flex gap-4 items-start">
                {e.data.titelbild && (
                  <img
                    src={e.data.titelbild}
                    alt=""
                    loading="lazy"
                    class="w-20 h-20 object-cover rounded-sm border border-[var(--color-border)] flex-shrink-0 opacity-90 group-hover:opacity-100 transition-opacity"
                  />
                )}
                <div>
                  <h3 class="heading-serif text-lg text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors leading-snug">
                    {e.data.titel}
                  </h3>
                  {e.data.untertitel && (
                    <p class="text-sm text-[var(--color-muted-foreground)]/80 mt-1 leading-relaxed">
                      {e.data.untertitel}
                    </p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <a href="/werke" class="inline-block text-sm text-[var(--color-accent)] underline underline-offset-4 hover:text-[var(--color-foreground)] transition-colors">
            Alle Werke ansehen →
          </a>
        </div>
      </section>
    )}

    <nav class="mt-16 pt-8 border-t border-[var(--color-border)]/40 text-sm">
      <a href="/blog" class="text-[var(--color-muted-foreground)] hover:text-[var(--color-accent)] transition-colors">
        ← Alle Einträge
      </a>
    </nav>
  </article>
</Layout>
