---
import Layout from "../../layouts/Layout.astro";
import HeroBanner from "../../components/HeroBanner.astro";
---

<Layout title="Journal – Istvan Seidel Lichtkunst" description="Journal und Werkstattnotizen zur Lichtkunst-Praxis von Istvan Seidel.">
  <HeroBanner title="Journal" subtitle="notizen aus der praxis" />

  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="text-center">
      <div class="text-xs tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4">Demnächst</div>
      <h2 class="heading-serif text-2xl mb-6">Erste Einträge folgen</h2>
      <p class="text-sm leading-relaxed text-[var(--color-muted-foreground)]">
        Werkstattnotizen, Lesefrüchte aus der Farbenlehre,
        kurze Texte zu einzelnen Arbeiten.
      </p>
    </div>
  </section>
</Layout>
