---
import Layout from "../../layouts/Layout.astro";
import HeroBanner from "../../components/HeroBanner.astro";
import { getCollection } from "astro:content";

const werke = (await getCollection("werke", ({ data }) => !data.ausblenden))
  .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf());
---

<Layout title="Werke – Istvan Seidel Lichtkunst" description="Lichtkunst-Werke von Istvan Seidel. Sky Art, Geometrie aus Licht, Lichtspuren.">
  <HeroBanner title="Werke" subtitle="ausgewählte Lichtkunst" />

  <section class="max-w-6xl mx-auto px-6 py-16">
    {werke.length === 0 ? (
      <div class="text-center max-w-xl mx-auto">
        <div class="text-xs tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4">Sammlung im Aufbau</div>
        <h2 class="heading-serif text-2xl mb-6">Werke folgen in Kürze</h2>
        <p class="text-sm leading-relaxed text-[var(--color-muted-foreground)]">
          Die Werkdokumentation wird Schritt für Schritt aufgebaut.
          Bis dahin geben die <a href="/nft" class="text-[var(--color-accent)] hover:underline underline-offset-4">NFT-Sammlungen</a>
          einen ersten Einblick.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {werke.map((werk) => (
          <a
            href={`/werke/${werk.id}`}
            class="nft-card block bg-[var(--color-card)] border border-[var(--color-border)] rounded-sm overflow-hidden hover:border-[var(--color-accent)]/60 transition-colors"
          >
            <div class="aspect-square bg-gradient-to-br from-[oklch(0.18_0.02_68)] to-[oklch(0.12_0.005_285)] flex items-center justify-center overflow-hidden">
              {werk.data.bild ? (
                <img src={werk.data.bild} alt={werk.data.titel} class="w-full h-full object-cover" />
              ) : (
                <div class="text-[var(--color-muted-foreground)]/40 text-xs tracking-[0.3em] uppercase">ohne Bild</div>
              )}
            </div>
            <div class="p-5 relative z-10">
              {werk.data.serie && (
                <div class="text-xs tracking-widest uppercase text-[var(--color-accent)] mb-2">{werk.data.serie}</div>
              )}
              <div class="heading-serif text-lg text-[var(--color-foreground)] mb-1">{werk.data.titel}</div>
              {werk.data.beschreibung_kurz && (
                <div class="text-xs text-[var(--color-muted-foreground)] mt-2 leading-relaxed">{werk.data.beschreibung_kurz}</div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
