---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const werke = await getCollection("werke", ({ data }) => !data.ausblenden);
  return werke.map((werk) => ({
    params: { slug: werk.id },
    props: { werk },
  }));
}

const { werk } = Astro.props;
const { Content } = await render(werk);

const datum = werk.data.datum.toLocaleDateString("de-DE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${werk.data.titel} – Lichtkunst`} description={werk.data.beschreibung_kurz}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    {werk.data.bild && (
      <div class="mb-12 -mx-6 sm:mx-0">
        <img
          src={werk.data.bild}
          alt={werk.data.titel}
          class="w-full h-auto rounded-sm border border-[var(--color-border)]"
        />
      </div>
    )}

    <header class="mb-10">
      {werk.data.serie && (
        <div class="text-xs tracking-[0.3em] uppercase text-[var(--color-accent)] mb-4">
          {werk.data.serie}
        </div>
      )}

      <h1 class="heading-display text-4xl md:text-5xl text-[var(--color-foreground)] tracking-[0.04em] mb-4 text-glow-amber">
        {werk.data.titel}
      </h1>

      <div class="text-sm text-[var(--color-muted-foreground)] uppercase tracking-widest">
        {datum}
      </div>
    </header>

    <div class="font-body text-[var(--color-muted-foreground)] leading-relaxed [&_h2]:heading-serif [&_h2]:text-2xl [&_h2]:text-[var(--color-foreground)] [&_h2]:mt-12 [&_h2]:mb-5 [&_h3]:font-medium [&_h3]:text-[var(--color-foreground)] [&_h3]:mt-8 [&_h3]:mb-3 [&_p]:mb-5 [&_ul]:list-disc [&_ul]:ml-6 [&_ul]:mb-5 [&_li]:mb-1 [&_em]:text-[var(--color-foreground)]/90 [&_strong]:text-[var(--color-foreground)] [&_a]:text-[var(--color-accent)] [&_a]:underline [&_a]:underline-offset-4 [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--color-accent)] [&_blockquote]:pl-5 [&_blockquote]:italic [&_blockquote]:text-[var(--color-foreground)]/80 [&_blockquote]:my-6 [&_img]:w-full [&_img]:h-auto [&_img]:rounded-sm [&_img]:border [&_img]:border-[var(--color-border)] [&_img]:my-10 [&_img]:-mx-6 [&_img]:sm:mx-0 [&_img]:max-w-[calc(100%+3rem)] [&_img]:sm:max-w-full">
      <Content />
    </div>

    {werk.data.getgems_url && (
      <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
        <a
          href={werk.data.getgems_url}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center px-6 py-3 rounded-sm bg-[var(--color-accent)] text-[var(--color-accent-foreground)] text-sm tracking-[0.15em] uppercase font-medium glow-amber-sm hover:glow-amber transition-shadow"
        >
          Auf Getgems ansehen →
        </a>
      </div>
    )}

    <nav class="mt-16 pt-8 border-t border-[var(--color-border)]/40 text-sm">
      <a href="/werke" class="text-[var(--color-muted-foreground)] hover:text-[var(--color-accent)] transition-colors">
        ← Alle Werke
      </a>
    </nav>
  </article>
</Layout>
