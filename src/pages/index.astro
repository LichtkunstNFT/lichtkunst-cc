---
import Layout from "../layouts/Layout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import { getCollection } from "astro:content";

const werke = (await getCollection("werke", ({ data }) => !data.ausblenden))
  .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf());

const aktuellesWerk = werke[0];

const blogEintraege = (await getCollection("blog", ({ data }) => !data.ausblenden))
  .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf())
  .slice(0, 3);

const zitate = [
  {
    text: "Die Farben sind Taten des Lichts, Taten und Leiden.",
    autor: "Johann Wolfgang von Goethe",
    werk: "Zur Farbenlehre",
  },
  {
    text: "Wäre nicht das Auge sonnenhaft, die Sonne könnt' es nie erblicken.",
    autor: "Johann Wolfgang von Goethe",
    werk: "Zur Farbenlehre",
  },
  {
    text: "Die Farbe ist eine Modifikation der Tätigkeit der Netzhaut.",
    autor: "Arthur Schopenhauer",
    werk: "Über das Sehn und die Farben",
  },
  {
    text: "Das Sehen ist eine Tätigkeit, nicht ein bloßes Empfangen.",
    autor: "Arthur Schopenhauer",
    werk: "Über das Sehn und die Farben",
  },
  {
    text: "Licht ist alles, was es gibt — alles andere ist nur sein Spiegel.",
    autor: "Walter Russell",
    werk: "Das Geheimnis des Lichts",
  },
  {
    text: "Licht scheint von innen, nicht von außen.",
    autor: "Walter Russell",
    werk: "Das Geheimnis des Lichts",
  },
];
---

<Layout>
  <HeroBanner title="Lichtkunst" subtitle="istvan seidel" compact />

  <section class="max-w-2xl mx-auto px-6 pt-8 pb-0 text-center">
    <blockquote id="random-zitat">
      <p
        class="font-display italic text-sm md:text-base leading-relaxed text-[var(--color-muted-foreground)]/85"
        data-zitat-text
      ></p>
      <footer class="mt-4 text-[0.65rem] tracking-[0.3em] uppercase text-[var(--color-accent)] not-italic">
        <span data-zitat-autor></span>
        <span class="text-[var(--color-muted-foreground)]/50 mx-2">·</span>
        <span data-zitat-werk class="text-[var(--color-muted-foreground)]/70 normal-case tracking-wider italic"></span>
      </footer>
    </blockquote>
  </section>

  <script is:inline define:vars={{ zitate }}>
    const z = zitate[Math.floor(Math.random() * zitate.length)];
    document.querySelector("[data-zitat-text]").textContent = `„${z.text}"`;
    document.querySelector("[data-zitat-autor]").textContent = z.autor;
    document.querySelector("[data-zitat-werk]").textContent = z.werk;
  </script>

  {werke.length > 0 && (
    <section class="mt-4">
      <div class="max-w-6xl mx-auto px-6 pt-1 pb-12">
        <div class="text-[0.65rem] tracking-[0.4em] uppercase text-[var(--color-accent)] mb-6 text-center animate-pulse-glow">
          Aktuelle Werke
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {werke.slice(0, 3).map((werk, i) => (
            <a href={`/werke/${werk.id}`} class="block group">
              {werk.data.bild && (
                <div class="overflow-hidden rounded-sm border border-[var(--color-border)] group-hover:glow-amber-sm transition-shadow duration-500 mb-4 aspect-square bg-[var(--color-card)]">
                  <img
                    src={werk.data.bild}
                    alt={werk.data.titel}
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
                  />
                </div>
              )}
              <div class="text-center">
                {werk.data.serie && (
                  <div class="text-[0.6rem] tracking-[0.3em] uppercase text-[var(--color-accent)] mb-2">
                    {werk.data.serie}
                  </div>
                )}
                <h2 class="heading-serif text-lg md:text-xl mb-2 text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors">
                  {werk.data.titel}
                  {i === 0 && (
                    <span class="block text-[0.55rem] tracking-[0.3em] uppercase text-[var(--color-accent)]/80 mt-1 font-normal">
                      Aktuell
                    </span>
                  )}
                </h2>
                {werk.data.beschreibung_kurz && (
                  <p class="text-xs leading-relaxed text-[var(--color-muted-foreground)] max-w-xs mx-auto">
                    {werk.data.beschreibung_kurz}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>

        <NewsletterForm />
      </div>
    </section>
  )}

  {blogEintraege.length > 0 && (
    <section class="border-t border-[var(--color-border)]/60">
      <div class="max-w-3xl mx-auto px-6 py-14">
        <div class="text-[0.65rem] tracking-[0.4em] uppercase text-[var(--color-accent)] mb-8 text-center">
          Aus dem Journal
        </div>

        <ul class="space-y-6">
          {blogEintraege.map((eintrag) => (
            <li class="border-b border-[var(--color-border)]/30 pb-6 last:border-0">
              <a href={`/blog/${eintrag.id}`} class="group block">
                <div class="text-[0.65rem] tracking-widest uppercase text-[var(--color-muted-foreground)]/60 mb-1">
                  {eintrag.data.datum.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}
                </div>
                <h3 class="heading-serif text-base md:text-lg text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors">
                  {eintrag.data.titel}
                </h3>
              </a>
            </li>
          ))}
        </ul>

        <div class="text-center mt-8">
          <a href="/blog" class="text-[0.65rem] tracking-[0.25em] uppercase text-[var(--color-muted-foreground)] hover:text-[var(--color-accent)] transition-colors">
            Alle Einträge →
          </a>
        </div>
      </div>
    </section>
  )}

  <section class="border-t border-[var(--color-border)]/60">
    <div class="max-w-2xl mx-auto px-6 py-14 text-center">
      <div class="text-[0.65rem] tracking-[0.4em] uppercase text-[var(--color-accent)] mb-4">
        NFT-Sammlungen
      </div>
      <h2 class="heading-serif text-xl md:text-2xl text-[var(--color-foreground)] mb-4">
        Auf der TON Blockchain
      </h2>
      <p class="text-sm leading-relaxed text-[var(--color-muted-foreground)] max-w-md mx-auto mb-6">
        Flüchtige Lichtphänomene als digitale Zeugnisse —
        einzigartig, nicht wiederholbar.
      </p>
      <a
        href="/nft"
        class="inline-flex items-center px-5 py-2 rounded-sm bg-[var(--color-accent)] text-[var(--color-accent-foreground)] text-xs tracking-[0.2em] uppercase font-medium glow-amber-sm hover:glow-amber transition-shadow"
      >
        Sammlungen ansehen →
      </a>
    </div>
  </section>
</Layout>
